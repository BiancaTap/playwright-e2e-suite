{
  "name": "playwright-e2e-suite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Playwright TypeScript E2E suite for automationexercise.com — Page Object Model, deterministic data, CI on every push.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "PWDEBUG=1 playwright test",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "install:browsers": "playwright install --with-deps chromium firefox webkit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-plugin-playwright": "^2.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "@faker-js/faker": "^9.3.0",
    "dotenv": "^16.4.7"
  }
}
